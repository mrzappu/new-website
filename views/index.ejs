            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: all 0.3s;
            text-decoration: none;
            display: block;
        }
        
        .category-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }
        
        .category-card i {
            font-size: 3rem;
            color: var(--accent-color);
            margin-bottom: 15px;
        }
        
        .category-card h5 {
            color: var(--primary-color);
            font-weight: 600;
            margin-bottom: 0;
        }
        
        .footer {
            background: var(--primary-color);
            color: white;
            padding: 60px 0 20px;
            margin-top: 50px;
        }
        
        .footer a {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            transition: color 0.3s;
        }
        
        .footer a:hover {
            color: white;
        }
        
        .footer h5 {
            color: white;
            margin-bottom: 20px;
            font-weight: 600;
        }
        
        .social-links {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }
        
        .social-links a {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }
        
        .social-links a:hover {
            background: var(--secondary-color);
            transform: translateY(-3px);
        }
        
        .discord-login {
            background: #5865F2;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        
        .discord-login:hover {
            background: #4752c4;
            transform: translateY(-2px);
            color: white;
        }
        
        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            border: 2px solid white;
        }
        
        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.5rem;
            }
            
            .category-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 576px) {
            .category-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-tshirt me-2"></i>SportsWear
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/shop">Shop</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="brandsDropdown" role="button" data-bs-toggle="dropdown">
                            Brands
                        </a>
                        <ul class="dropdown-menu">
                            <% if (brands && brands.length > 0) { %>
                                <% brands.forEach(brand => { %>
                                    <li><a class="dropdown-item" href="/shop?brand=<%= encodeURIComponent(brand) %>"><%= brand %></a></li>
                                <% }); %>
                            <% } %>
                        </ul>
                    </li>
                    <% if (user && user.is_admin) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin">Admin Panel</a>
                        </li>
                    <% } %>
                </ul>
                <ul class="navbar-nav">
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/cart">
                                <i class="fas fa-shopping-cart"></i> Cart
                                <span id="cart-count" class="badge bg-danger" style="display: none;">0</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/history">Orders</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown">
                                <div class="d-flex align-items-center">
                                    <% if (user.avatar) { %>
                                        <img src="https://cdn.discordapp.com/avatars/<%= user.discord_id %>/<%= user.avatar %>.png" class="user-avatar me-2">
                                    <% } else { %>
                                        <i class="fas fa-user-circle me-2"></i>
                                    <% } %>
                                    <span><%= user.username %></span>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/profile">Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/logout">Logout</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">
                                <button class="discord-login">
                                    <i class="fab fa-discord"></i> Login
                                </button>
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <h1 class="hero-title">Welcome to SportsWear</h1>
            <p class="hero-subtitle">Your premier destination for Adidas, Puma, Under Armour, New Balance, and custom apparel including Hammper style and esports gear</p>
            <a href="/shop" class="btn-hero">Shop Now</a>
        </div>
    </section>

    <!-- Brand Section -->
    <section class="brand-section">
        <div class="container">
            <h2 class="section-title">Our Brands</h2>
            <div class="row">
                <div class="col-md-3 col-6">
                    <a href="/shop?brand=Adidas" class="brand-logo d-block">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/2/20/Adidas_Logo.svg" alt="Adidas">
                    </a>
                </div>
                <div class="col-md-3 col-6">
                    <a href="/shop?brand=Puma" class="brand-logo d-block">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/8/88/Puma_AG.svg" alt="Puma">
                    </a>
                </div>
                <div class="col-md-3 col-6">
                    <a href="/shop?brand=Under Armour" class="brand-logo d-block">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/2/24/Under_Armour_Logo.svg" alt="Under Armour">
                    </a>
                </div>
                <div class="col-md-3 col-6">
                    <a href="/shop?brand=New Balance" class="brand-logo d-block">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/e/ea/New_Balance_logo.svg" alt="New Balance">
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Products -->
    <section class="container">
        <h2 class="section-title">Featured Products</h2>
        <div class="product-grid">
            <% if (featuredProducts && featuredProducts.length > 0) { %>
                <% featuredProducts.forEach(product => { %>
                    <div class="product-card">
                        <div class="product-image">
                            <span class="product-badge"><%= product.brand %></span>
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" loading="lazy">
                        </div>
                        <div class="product-info">
                            <div class="product-category"><%= product.category %></div>
                            <h3 class="product-title"><%= product.name %></h3>
                            <div class="product-price">₹<%= Number(product.price).toFixed(2) %></div>
                            <a href="/product/<%= product.id %>" class="btn-product">View Details</a>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No products available at the moment.</p>
                </div>
            <% } %>
        </div>
    </section>

    <!-- Categories -->
    <section class="container mt-5">
        <h2 class="section-title">Shop by Category</h2>
        <div class="category-grid">
            <a href="/shop?category=T-Shirts" class="category-card">
                <i class="fas fa-tshirt"></i>
                <h5>T-Shirts</h5>
            </a>
            <a href="/shop?category=Hoodies" class="category-card">
                <i class="fas fa-tshirt"></i>
                <h5>Hoodies</h5>
            </a>
            <a href="/shop?category=Sports Wear" class="category-card">
                <i class="fas fa-running"></i>
                <h5>Sports Wear</h5>
            </a>
            <a href="/shop?category=Esports" class="category-card">
                <i class="fas fa-gamepad"></i>
                <h5>Esports</h5>
            </a>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5>About Us</h5>
                    <p>Your premier destination for premium sports wear and custom apparel. We bring you the best brands and unique designs including Hammper style and esports merchandise.</p>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-discord"></i></a>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="/shop">Shop</a></li>
                        <li><a href="/terms">Terms</a></li>
                        <li><a href="/privacy">Privacy</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Brands</h5>
                    <ul class="list-unstyled">
                        <li><a href="/shop?brand=Adidas">Adidas</a></li>
                        <li><a href="/shop?brand=Puma">Puma</a></li>
                        <li><a href="/shop?brand=Under Armour">Under Armour</a></li>
                        <li><a href="/shop?brand=New Balance">New Balance</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Contact</h5>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-map-marker-alt me-2"></i> India</li>
                        <li><i class="fas fa-envelope me-2"></i> support@sportswear.com</li>
                        <li><i class="fas fa-phone me-2"></i> +91 9876543210</li>
                    </ul>
                </div>
            </div>
            <hr class="bg-light">
            <div class="text-center">
                <p>&copy; 2024 SportsWear. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Update cart count
        function updateCartCount() {
            <% if (user) { %>
                fetch('/cart/count')
                    .then(res => res.json())
                    .then(data => {
                        const badge = document.getElementById('cart-count');
                        if (badge) {
                            badge.textContent = data.count;
                            badge.style.display = data.count > 0 ? 'inline' : 'none';
                        }
                    })
                    .catch(err => console.error('Error:', err));
            <% } %>
        }
        
        document.addEventListener('DOMContentLoaded', updateCartCount);
    </script>
</body>
</html>
